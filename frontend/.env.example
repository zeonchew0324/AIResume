# ---------------------------------------------------------------------------
# Frontend environment variables (Vite)
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# Only variables prefixed with VITE_ are exposed to the browser, so never put
# secret keys here — the anon key below is safe to ship to the client.
# ---------------------------------------------------------------------------

# Supabase project URL.
# Supabase Dashboard -> Project Settings -> API -> Project URL
# Example: https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anonymous (public) API key.
# Supabase Dashboard -> Project Settings -> API -> Project API keys -> anon public
VITE_SUPABASE_ANON_KEY=
