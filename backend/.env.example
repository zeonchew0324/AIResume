# ---------------------------------------------------------------------------
# Backend environment variables
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# Never commit the filled-in `.env` — it is gitignored.
# ---------------------------------------------------------------------------

# OpenAI API key — powers resume analysis, improvement, and cover-letter
# generation (model: gpt-4o-mini via LangChain).
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Async Postgres connection string for the resumes database (SQLAlchemy + asyncpg).
# Must use the `postgresql+asyncpg://` scheme.
# From Supabase: Project Settings -> Database -> Connection string -> URI,
# then swap the scheme to `postgresql+asyncpg://`.
# Example: postgresql+asyncpg://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DB_URL=""

# Supabase JWT secret — used to verify the access tokens sent by the frontend.
# Supabase Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=""
